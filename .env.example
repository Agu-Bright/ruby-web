# Ruby+ Web Configuration
# Copy to .env.local and fill in values

# Backend API base URL (NestJS server)
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Internal API URL for server-side calls (can be same or internal network address)
API_URL=http://localhost:3001/api

# Session encryption secret (generate a random 32+ char string)
SESSION_SECRET=change-me-to-a-random-secret-at-least-32-chars

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sign in with Apple — the Services ID from Apple Developer Portal
# (not the iOS app's bundle ID — a separate Services ID with Sign in with Apple enabled
#  and rubyplus.net configured as a Domain + Return URL)
# Example: com.rubyplus.business.signin
NEXT_PUBLIC_APPLE_SERVICES_ID=

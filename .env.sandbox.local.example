# Admin web — SANDBOX local dev env
#
# Copy to `.env.sandbox.local` (gitignored) then start with:
#   npx next dev --env-file .env.sandbox.local
# OR temporarily symlink as .env.local:
#   cp .env.sandbox.local .env.local
#
# For deployed sandbox: Vercel → Project → Settings → Environment Variables
# → set these for the "Preview" environment tracking the `sandbox` branch.
# Don't commit secrets — this file is the placeholder template only.

# Backend URLs
NEXT_PUBLIC_API_URL=https://sandbox-api.rubyaggregators.com/api
API_URL=https://sandbox-api.rubyaggregators.com/api

# Frontend URL — used for OAuth redirects, email links, etc.
NEXT_PUBLIC_APP_URL=https://sandbox-admin.rubyaggregators.com

# Session signing — separate from production. Generate:
#   openssl rand -base64 32
SESSION_SECRET=
